{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "main",
  "description": "Tahlk main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "dialog:allow-save",
    "dialog:allow-open",
    "clipboard-manager:allow-write-text"
  ]
}
